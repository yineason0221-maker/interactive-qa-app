# Dependencies (雲端平台會自動 npm install，不需要推送到 GitHub)
node_modules/
backend/node_modules/
frontend/node_modules/

# Frontend Production Build (雲端平台會自動 npm run build)
frontend/dist/
frontend/dist-ssr/

# SQLite Database (本地測試的資料庫，雲端會自動全新生成，不要推送到 GitHub)
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
backend/database.sqlite

# Media uploads during local test (可由管理員於後台線上上傳)
backend/uploads/*
!backend/uploads/.gitkeep

# Environment variables
.env
.env.local
.env.development.local
.env.production.local

# Logs and OS files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
Thumbs.db
